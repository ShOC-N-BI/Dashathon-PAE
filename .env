# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# Docker note: LM Studio runs on your host machine.
# Use host.docker.internal instead of 127.0.0.1 when running in Docker.

# IRC
IRC_SERVER=10.5.185.72
IRC_PORT=6667
IRC_CHANNEL=#app_dev

# AI — set AI_ENDPOINT to either LM Studio or NanoGPT URL
# Provider is detected automatically from the URL:
#   LM Studio:  http://host.docker.internal:4334/v1/chat/completions
#   NanoGPT:    https://nano-gpt.com/api/v1/chat/completions
AI_ENDPOINT=http://10.5.185.55:4334/v1/chat/completions
AI_MODEL=google/gemma-4-e4b
AI_API_KEY=
AI_TIMEOUT=60

# Orchestrator
ORCHESTRATOR_BASE_URL=http://10.5.185.29:3016
#http://10.5.185.29:3016/paeinputs-sse
ORCHESTRATOR_API_KEY=test

# SSE
SSE_RETRY_DELAY=5

# GBC API — endpoint to push mapped assessments to
GBC_API_URL=http://10.5.185.29:3016/paeoutputs


# Database
DB_HOST=10.5.185.53
DB_NAME=shooca_db
DB_USER=shooca
DB_PASSWORD=shooca222
DB_PORT=5432
IRC_NICKNAME=PAE_Bot_ShocN

# Leave blank to use the same endpoint as AI_ENDPOINT
TRIAGE_ENDPOINT=
TRIAGE_MODEL=google/gemma-4-e4b
TRIAGE_TIMEOUT=
