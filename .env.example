# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# Docker note: when PAE runs in Docker and another service runs on the host,
# use host.docker.internal instead of 127.0.0.1.

# ---------------------------------------------------------------------------
# IRC
# ---------------------------------------------------------------------------
IRC_SERVER=10.5.185.72
IRC_PORT=6667
IRC_CHANNEL=#app_dev,#c2_coord
IRC_NICKNAME=PAE_Bot_ShocN2

# ---------------------------------------------------------------------------
# AI — Battle Assessment
# Provider is detected automatically from the URL.
#   LM Studio:  http://10.5.185.55:4334/v1/chat/completions
#   NanoGPT:    https://nano-gpt.com/api/v1/chat/completions
# AI_API_KEY is required only for NanoGPT.
# ---------------------------------------------------------------------------
AI_ENDPOINT=http://10.5.185.55:4334/v1/chat/completions
AI_MODEL=google/gemma-4-e4b
AI_API_KEY=
AI_TIMEOUT=60

# ---------------------------------------------------------------------------
# AI — Triage (fast pre-filter, runs before full assessment)
# Leave TRIAGE_ENDPOINT blank to reuse AI_ENDPOINT.
# ---------------------------------------------------------------------------
TRIAGE_ENDPOINT=
TRIAGE_MODEL=google/gemma-4-e4b
TRIAGE_TIMEOUT=10

# ---------------------------------------------------------------------------
# Classify API — enriches messages with callsigns and entities
# ---------------------------------------------------------------------------
CLASSIFY_API_URL=http://10.5.185.30:3060/classify
CLASSIFY_TIMEOUT=5

# ---------------------------------------------------------------------------
# Track API — validates SSE retrigger events
# Rejects retriggers when the track ID has no data on this endpoint.
# Leave blank to disable validation.
# ---------------------------------------------------------------------------
TRACK_API_URL=http://10.5.185.29:3021/tracks
TRACK_API_TIMEOUT=5

# ---------------------------------------------------------------------------
# Orchestrator — receives validated PaeOutput records
# ---------------------------------------------------------------------------
ORCHESTRATOR_BASE_URL=http://emulator:3016
ORCHESTRATOR_API_KEY=

SSE_RETRY_DELAY=5

# ---------------------------------------------------------------------------
# GBC API — pushes full battle JSON
# ---------------------------------------------------------------------------
GBC_API_URL=http://emulator:3016/paeoutputs

# ---------------------------------------------------------------------------
# Database — PostgreSQL store for assessments (optional)
# Set all four fields to enable DB writes.
# ---------------------------------------------------------------------------
DB_HOST=10.5.185.21
DB_NAME=shooca_db
DB_USER=shooca
DB_PASSWORD=shooca222
DB_PORT=5432

# ---------------------------------------------------------------------------
# Test Run identifier — controls the DDRR-rr request ID format
# DD = day, RR = run number. The request counter (rr) auto-increments and
# resets to 0 when RUN_NUMBER changes. Both can be edited live from the UI.
# ---------------------------------------------------------------------------
RUN_DAY=01
RUN_NUMBER=01
