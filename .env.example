# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# Docker note: LM Studio runs on your host machine.
# Use host.docker.internal instead of 127.0.0.1 when running in Docker.
# e.g. LM_STUDIO_URL=http://host.docker.internal:4334/v1/chat/completions

# IRC
IRC_SERVER=10.5.185.72
IRC_PORT=6667
IRC_CHANNEL=#app_dev

# AI Provider — set to 'lmstudio' or 'nanogpt'
AI_PROVIDER=lmstudio

# LM Studio
LM_STUDIO_URL=http://10.5.185.55:4334/v1/chat/completions
LM_MODEL=google/gemma-4-e4b
LM_TIMEOUT=20

# NanoGPT
NANOGPT_API_URL=https://nano-gpt.com/api/v1/chat/completions
NANOGPT_API_KEY=sk-nano-your-key-here
NANOGPT_MODEL=gpt-4o

# Orchestrator
ORCHESTRATOR_BASE_URL=http://10.5.185.XX:PORT
ORCHESTRATOR_API_KEY=your-api-key-here

# SSE
SSE_RETRY_DELAY=5

# Battle API (set when ready to push live)
BATTLE_API_URL=

# Database
DB_HOST=10.5.185.53
DB_NAME=shooca_db
DB_USER=shooca
DB_PASSWORD=shooca222
DB_PORT=5432
